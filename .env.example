NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/agency-erp
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
# Comma-separated list of allowed frontend origins (required for production login)
CORS_ORIGIN=http://localhost:3000,https://dashboards.editcomedia.com,https://dashboards-frontend.vercel.app
UPLOAD_DIR=./uploads
LOG_LEVEL=info
